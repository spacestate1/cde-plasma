post_install() {
    cat <<EOF

cde-plasma installed system-wide.

To activate the CDE theme for your user, run as your normal user (NOT root):

    cde-plasma-apply

To revert later (without uninstalling the package):

    cde-plasma-unapply

To flip between the bundled light and dark CDE modes without a full Global
Theme re-apply:

    cde-plasma-mode light
    cde-plasma-mode dark

EOF
}

post_upgrade() {
    post_install "$@"
}
